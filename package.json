{
  "name": "chiayiyouthlabclock",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude tests/firestore-rules.test.ts --exclude 'tests/e2e/**'",
    "test:all": "vitest run --exclude 'tests/e2e/**'",
    "test:watch": "vitest --exclude 'tests/e2e/**'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "audit:prod": "npm audit --audit-level=high --omit=dev",
    "audit:report": "npm audit --json > audit-report.json",
    "firebase:rules:test": "vitest run tests/firestore-rules.test.ts",
    "firebase:rules:deploy": "npx firebase-tools deploy --only firestore:rules"
  },
  "dependencies": {
    "@sentry/react": "^10.53.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@netlify/functions": "^5.1.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.6"
  }
}
